<file path="waybar/style.css">
* {
    border: none;
    border-radius: 0;
    /* Fuente sans-serif limpia para asemejarse a Segoe UI */
    font-family: "Ubuntu", "Segoe UI", sans-serif;
    font-size: 13px;
    min-height: 0;
}

window#waybar {
    /* Gradiente característico de Windows Vista (Negro/Gris translúcido con reflejo cristalino) */
    background: linear-gradient(
        to bottom,
        rgba(20, 30, 35, 0.55) 0%,
        rgba(10, 15, 18, 0.70) 50%,
        rgba(2, 5, 5, 0.85) 52%,
        rgba(15, 20, 25, 0.75) 100%
    ); 
    
    color: #FFFFFF;
    /* Bisel superior brillante clásico de Windows Aero */
    border-top: 1px solid rgba(255, 255, 255, 0.4);
    border-bottom: 1px solid rgba(0, 0, 0, 0.6);
    text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
}

/* Efecto de botones de la barra de tareas de Windows Vista */
#workspaces button {
    padding: 0 15px;
    color: rgba(255, 255, 255, 0.7);
    font-weight: normal;
    margin: 4px 2px;
    border-radius: 3px;
    /* Borde sutil transparente */
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: linear-gradient(to bottom, rgba(255,255,255,0.05), rgba(0,0,0,0.1));
    transition: all 0.2s ease-in-out;
}

/* Aplicación/Workspace activa (Resaltado celeste Frutiger) */
#workspaces button.active {
    color: #ffffff;
    background: linear-gradient(
        to bottom,
        rgba(100, 200, 255, 0.45) 0%,
        rgba(30, 140, 230, 0.25) 50%,
        rgba(0, 80, 180, 0.5) 52%,
        rgba(50, 160, 240, 0.4) 100%
    );
    border: 1px solid rgba(120, 210, 255, 0.6);
    box-shadow: inset 0 0 5px rgba(255,255,255,0.4);
}

/* Hover al pasar el mouse por encima */
#workspaces button:hover {
    background: linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.3) 0%,
        rgba(255, 255, 255, 0.1) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.4);
}

/* Módulos globales del sistema (Área de notificación / System Tray) */
#clock,
#battery,
#network,
#pulseaudio,
#backlight, 
#cpu,
#memory,
#keyboard-state,
#tray {
    padding: 0 8px;
    color: #e0f2fe;
}

/* Reloj específico al estilo de la bandeja de Vista */
#clock {
    font-size: 11px;
    font-weight: bold;
    color: #ffffff;
    padding-left: 10px;
    padding-right: 10px;
    border-left: 1px solid rgba(255, 255, 255, 0.15);
}






#custom-wallpaper {
    color: #38bdf8;
    padding: 0 10px;
}

#custom-wallpaper:hover {
    color: #0ea5e9;
    text-shadow: 0 0 6px rgba(14, 165, 233, 0.8);
}
</file>

